# LLM provider for the LangGraph reference agent (the only external API call)
OPENAI_API_KEY=sk-...

# Paths (defaults are fine for local development)
AUDIT_LOG_PATH=./audit.jsonl
VAULT_PATH=./vault.jsonl
REVIEW_QUEUE_PATH=./review_queue.jsonl
DB_PATH=./data/synthetic_fs.sqlite

# Privacy Filter device: "cpu" (default, reproducible) or "cuda"
PRIVACY_FILTER_DEVICE=cpu

# Customer API port
CUSTOMER_API_PORT=8100
